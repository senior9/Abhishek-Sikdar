{% comment %}

  GIFT GUIDE HERO SECTION
  -Desktop: Full-width top banner + split content / image row with configurable ratio.
  -Mobile:  Top banner hidden, content stacksabove image, button overlays image centre.
  -Button locked to 220×50 px.
  -Arrow accepts inline SVG with width/heightand currentColor-aware tinting.
{% endcomment %}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link
  href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700;800&display=swap"
  rel="stylesheet"
>

{%- liquid
  assign top_banner = section.settings.top_banner_image
  assign right_image = section.settings.right_image
  assign right_image_mob = section.settings.right_image_mobile
  assign button_url = section.settings.button_url
  assign arrow_svg = section.settings.arrow_svg
-%}

{% comment %}  SCOPED THEME VARIABLES  {% endcomment %}
<style>
  #shopify-section-{{ section.id }} {
    --ggh-bg:                {{ section.settings.section_bg_color }};
    --ggh-placeholder-bg:    {{ section.settings.placeholder_bg_color }};

    /* Typography */
    --ggh-font-family:       {{ section.settings.font_family }};
    --ggh-title-color:       {{ section.settings.title_color }};
    --ggh-title-size:        {{ section.settings.title_size }}px;
    --ggh-title-weight:      {{ section.settings.title_weight }};
    --ggh-desc-color:        {{ section.settings.desc_color }};
    --ggh-desc-size:         {{ section.settings.desc_size }}px;
    --ggh-desc-weight:       {{ section.settings.desc_weight }};
    

    /* Layout */
    --ggh-left-width:        {{ section.settings.left_width }}fr;
    --ggh-right-width:       {{ section.settings.right_width }}fr;
    --ggh-content-pad-x:     {{ section.settings.content_padding }}px;
    --ggh-content-pad-y:     {{ section.settings.section_padding }}px;

    /* Button */
    --ggh-btn-mob-x:         {{ section.settings.btn_mobile_pos_x }}%;
    --ggh-btn-mob-y:         {{ section.settings.btn_mobile_pos_y }}%;
    --ggh-btn-bg:            {{ section.settings.btn_bg_color }};
    --ggh-btn-text:          {{ section.settings.btn_text_color }};
    --ggh-btn-border-color:  {{ section.settings.btn_border_color }};
    --ggh-btn-border-width:  {{ section.settings.btn_border_width }}px;
    --ggh-btn-hover-bg:      {{ section.settings.btn_hover_bg_color }};
    --ggh-btn-hover-text:    {{ section.settings.btn_hover_text_color }};
    --ggh-btn-font-size:     {{ section.settings.btn_font_size }}px;
    --ggh-btn-font-weight:   {{ section.settings.btn_font_weight }};
    --ggh-btn-letter-sp:     {{ section.settings.btn_letter_spacing }}px;
    --ggh-btn-radius:        {{ section.settings.btn_border_radius }}px;

    /* Arrow Icon */
    --ggh-arrow-w:           {{ section.settings.arrow_width }}px;
    --ggh-arrow-h:           {{ section.settings.arrow_height }}px;
    --ggh-arrow-color:       {{ section.settings.arrow_color }};
    --ggh-arrow-hover-color: {{ section.settings.arrow_hover_color }};

    /* Image focal points */
    --ggh-img-x:             {{ section.settings.image_position_x }}%;
    --ggh-img-y:             {{ section.settings.image_position_y }}%;
    --ggh-img-mob-x:         {{ section.settings.image_position_mobile_x }}%;
    --ggh-img-mob-y:         {{ section.settings.image_position_mobile_y }}%;
  }

  /* BASE SECTION*/
  #shopify-section-{{ section.id }} .gift-guide-hero {
    width: 100%;
    overflow: hidden;
    background-color: var(--ggh-bg);
    font-family: var(--ggh-font-family);
  }

  /*  TOP BANNER (desktop only)  */
  #shopify-section-{{ section.id }} .gift-guide-hero_top {
    width: 100%;
    line-height: 0;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_top-image {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  /*  BOTTOM GRID  */
  #shopify-section-{{ section.id }} .gift-guide-hero_bottom {
    display: grid;
    grid-template-columns: var(--ggh-left-width) var(--ggh-right-width);
    align-items: stretch;
  }

  /*  CONTENT COLUMN  */
  #shopify-section-{{ section.id }} .gift-guide-hero_content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    box-sizing: border-box;
    min-height: 402px;
    padding: var(--ggh-content-pad-y) var(--ggh-content-pad-x);
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_title {
    margin: 0 0 20px;
    color: var(--ggh-title-color);
    font-size: var(--ggh-title-size);
    font-weight: var(--ggh-title-weight);
    line-height: 1.1;
    letter-spacing: -0.5px;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_description {
    margin: 0 0 32px;
    color: var(--ggh-desc-color);
    font-size: var(--ggh-desc-size);
    font-weight: var(--ggh-desc-weight);
    line-height: 1.6;
  }

  /*  BUTTON  */
  #shopify-section-{{ section.id }} .gift-guide-hero_btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    overflow: hidden;
    cursor: pointer;
    white-space: nowrap;

    /* Fixed size per request */
    width: 220px;
    height: 50px;
    padding: 0;

    /* Theme */
    background-color: var(--ggh-btn-bg);
    color: var(--ggh-btn-text);
    font-family: inherit;
    font-size: var(--ggh-btn-font-size);
    font-weight: var(--ggh-btn-font-weight);
    letter-spacing: var(--ggh-btn-letter-sp);
    text-transform: uppercase;
    border: var(--ggh-btn-border-width) solid var(--ggh-btn-border-color);
    border-radius: var(--ggh-btn-radius);

    /* Animation */
    transition: color 0.3s ease;
  }

  /* Swipe-fill hover background */
  #shopify-section-{{ section.id }} .gift-guide-hero_btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background-color: var(--ggh-btn-hover-bg);
    transform: translateX(-100%);
    transition: transform 0.3s ease;
    z-index: 0;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_btn:hover::before {
    transform: translateX(0);
  }

  /* Hover text forced to black */
  #shopify-section-{{ section.id }} .gift-guide-hero_btn:hover {
   color: var(--ggh-btn-hover-text);
  }

  /* Children above fill layer */
  #shopify-section-{{ section.id }} .gift-guide-hero_btn > * {
    position: relative;
    z-index: 1;
  }

  /*  ARROW ICON  */
  #shopify-section-{{ section.id }} .btn-arrow {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: var(--ggh-arrow-w);
    height: var(--ggh-arrow-h);
    color: var(--ggh-arrow-color);
    transition: color 0.3s ease;
  }

  #shopify-section-{{ section.id }} .btn-arrow svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_btn:hover .btn-arrow {
    color: var(--ggh-arrow-hover-color);
  }

  /* Hide mobile button on desktop */
  #shopify-section-{{ section.id }} .gift-guide-hero_btn--mobile {
    display: none;
  }

  /*  IMAGE COLUMN  */
  #shopify-section-{{ section.id }} .gift-guide-hero_visual {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 402px;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_image--desktop {
    object-position: var(--ggh-img-x) var(--ggh-img-y);
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_image--mobile {
    display: none;
    object-position: var(--ggh-img-mob-x) var(--ggh-img-mob-y);
  }

  /*  PLACEHOLDERS  */
  #shopify-section-{{ section.id }} .gift-guide-hero_placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    background-color: var(--ggh-placeholder-bg);
    border: 2px dashed #cccccc;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_placeholder--top {
    min-height: 340px;
  }

  #shopify-section-{{ section.id }} .gift-guide-hero_placeholder--visual {
    min-height: 402px;
    height: 100%;
  }

  /* MOBILE  (max-width: 768px)*/
  @media screen and (max-width: 768px) {
    #shopify-section-{{ section.id }} .gift-guide-hero_top {
      display: none;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_bottom {
      display: flex;
      flex-direction: column;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_content {
      order: 1;
      align-items: center;
      min-height: auto;
      padding: 40px 24px 30px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_title {
      margin-bottom: 16px;
      font-size: 32px;
      font-weight: 700;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_description {
      margin: 0 auto;
      font-size: 14px;
      line-height: 1.5;
      max-width: 300px;
      text-align: center;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_btn--desktop {
      display: none;
    }

    /* Mobile overlay button */
    #shopify-section-{{ section.id }} .gift-guide-hero_btn--mobile {
      display: inline-flex !important;
      position: absolute;
      top: var(--ggh-btn-mob-y);
      left: var(--ggh-btn-mob-x);
      transform: translate(-50%, -50%);
      z-index: 10;
      width: 220px;
      height: 50px;
      padding: 0;
      font-size: 13px;
      font-weight: 500;
      letter-spacing: 2px;
    }

    /* Image area */
    #shopify-section-{{ section.id }} .gift-guide-hero_visual {
      order: 2;
      height: 380px;
      min-height: 380px;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_image--desktop {
      display: none;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_image--mobile {
      display: block;
    }
  }

  /*  Extra small phones  */
  @media screen and (max-width: 480px) {
    #shopify-section-{{ section.id }} .gift-guide-hero_title {
      font-size: 28px;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_description {
      font-size: 13px;
    }

    #shopify-section-{{ section.id }} .gift-guide-hero_visual {
      height: 340px;
      min-height: 340px;
    }
  }
</style>

{% comment %}  MARKUP  {% endcomment %}
<section class="gift-guide-hero">
  {% comment %} 1. Top Banner desktop only {% endcomment %}
  <div class="gift-guide-hero_top">
    {%- if top_banner -%}
      <img
        src="{{ top_banner | image_url: width: 2000 }}"
        alt="{{ top_banner.alt | escape | default: 'Gift Guide Banner' }}"
        class="gift-guide-hero_top-image"
        width="2000"
        height=""
        loading="eager"
      >
    {%- else -%}
      <div class="gift-guide-hero_placeholder gift-guide-hero_placeholder--top">
        <p>Add Top Banner Image</p>
      </div>
    {%- endif -%}
  </div>

  {% comment %} 2. Bottom Row  Content + Image {% endcomment %}
  <div class="gift-guide-hero_bottom">
    {% comment %} Left: Text content {% endcomment %}
    <div class="gift-guide-hero_content">
      <h1 class="gift-guide-hero_title">
        {{ section.settings.main_title | escape }}
      </h1>

      <p class="gift-guide-hero_description">
        {{ section.settings.description | escape }}
      </p>

      <button type="button" class="gift-guide-hero_btn gift-guide-hero_btn--desktop">
        <span class="btn-label">{{ section.settings.button_text | escape }}</span>

        <span class="btn-arrow">
          {%- if arrow_svg != blank -%}
            {{ arrow_svg }}
          {%- else -%}
            →
          {%- endif -%}
        </span>
      </button>
    </div>

    {% comment %} Right: Image + mobile CTA overlay {% endcomment %}
    <div class="gift-guide-hero_visual">
      {%- if right_image or right_image_mob -%}
        {% comment %} Desktop image {% endcomment %}
        {%- if right_image -%}
          <img
            src="{{ right_image | image_url: width: 1500 }}"
            alt="{{ right_image.alt | escape | default: 'Gift Guide' }}"
            class="gift-guide-hero_image gift-guide-hero_image--desktop"
            width="1500"
            height=""
            loading="lazy"
          >
        {%- endif -%}

        {% comment %} Mobile image (dedicated or fallback) {% endcomment %}
        {%- if right_image_mob -%}
          <img
            src="{{ right_image_mob | image_url: width: 800 }}"
            alt="{{ right_image_mob.alt | escape | default: 'Gift Guide' }}"
            class="gift-guide-hero_image gift-guide-hero_image--mobile"
            width="800"
            height=""
            loading="lazy"
          >
        {%- elsif right_image -%}
          <img
            src="{{ right_image | image_url: width: 800 }}"
            alt="{{ right_image.alt | escape | default: 'Gift Guide' }}"
            class="gift-guide-hero_image gift-guide-hero_image--mobile"
            width="800"
            height=""
            loading="lazy"
          >
        {%- endif -%}

        {% comment %} Mobile-only centred button {% endcomment %}
        <button type="button" class="gift-guide-hero_btn gift-guide-hero_btn--mobile">
          <span class="btn-label">{{ section.settings.button_text | escape }}</span>

          <span class="btn-arrow">
            {%- if arrow_svg != blank -%}
              {{ arrow_svg }}
            {%- else -%}
              →
            {%- endif -%}
          </span>
        </button>

      {%- else -%}
        <div class="gift-guide-hero_placeholder gift-guide-hero_placeholder--visual">
          <p>Add Right Side Image</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% comment %}  SCRIPTS  {% endcomment %}
<script>
  (function () {
    'use strict';

    var url = {{ button_url | json }};
    if (!url) return;

    var section = document.getElementById('shopify-section-{{ section.id }}');
    if (!section) return;

    section.querySelectorAll('.gift-guide-hero_btn').forEach(function (btn) {
      btn.addEventListener('click', function () {
        window.location.href = url;
      });
    });
  })();
</script>

