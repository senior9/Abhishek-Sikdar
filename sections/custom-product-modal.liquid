  const resolveColorHex = (name) => {
    if (!name || typeof name !== 'string') return '#888888';
    const k = name.toLowerCase().replace(/[\s\-_\.]/g, '');
    return COLOR_HEX_MAP[k] || '#888888';
  };

  const customModal = document.getElementById('customProductModal');
  const customOverlay = document.getElementById('customProductModalOverlay');
  const customCloseBtn = document.getElementById('customProductModalClose');
  const customColorContainer = document.getElementById('customModalColorOptions');
  const customColorWrapper = document.getElementById('customModalColorOptionContainer');
  const customSizeWrapper = document.getElementById('customModalSizeWrapper');
  const customSizeTrigger = customSizeWrapper.querySelector('.custom-size-trigger');
  const customSizeValueEl = document.getElementById('customModalSizeValue');
  const customSizeOptions = document.getElementById('customModalSizeOptions');
  const customSizeCaret = document.getElementById('customSizeCaret');
  const customSizeHidden = document.getElementById('customModalSizeSelect');
  const customDefaultSizes = ['XS', 'S', 'M', 'L', 'XL'];

  const buildCustomColors = (data) => {
    customColorContainer.innerHTML = '';
    if (!data || !data.trim()) {
      customColorWrapper.style.display = 'none';
      return;
    }
    customColorWrapper.style.display = 'flex';

    const colors = data.split(',').map((c) => c.trim()).filter(Boolean);
    const customSlider = document.createElement('div');
    customSlider.className = 'custom-slider';
    customColorContainer.appendChild(customSlider);

    let hasClicked = false;

    colors.forEach((color, index) => {
      const hex = resolveColorHex(color);
      const ellipse = document.createElement('div');
      ellipse.className = 'custom-color-split-option';
      ellipse.dataset.color = color;
      ellipse.style.borderLeftColor = hex;

      ellipse.innerHTML = `
        <div class="custom-color-strip" style="background-color: ${hex};"></div>
        <span class="custom-color-text">${color}</span>
      `;

      ellipse.addEventListener('click', () => {
        customColorContainer.querySelectorAll('.custom-color-split-option').forEach((opt) => {
          opt.classList.remove('custom-active');
        });
        ellipse.classList.add('custom-active');

        if (index === 0) customSlider.classList.remove('custom-right');
        else customSlider.classList.add('custom-right');

        if (!hasClicked) {
          customSlider.classList.add('custom-active');
          hasClicked = true;
        }
      });

      customColorContainer.appendChild(ellipse);
    });
  };

  const buildCustomSizes = (data) => {
    customSizeOptions.innerHTML = '';
    customSizeValueEl.textContent = 'Choose your size';
    customSizeHidden.value = '';

    const sizes = data && data.trim()
      ? data.split(',').map((s) => s.trim()).filter(Boolean)
      : customDefaultSizes;

    sizes.forEach((s) => {
      const li = document.createElement('li');
      li.textContent = s;
      li.dataset.value = s;
      li.addEventListener('click', () => {
        customSizeValueEl.textContent = s;
        customSizeHidden.value = s;
        customSizeOptions.querySelectorAll('li').forEach((item) => item.classList.remove('custom-selected'));
        li.classList.add('custom-selected');
        closeCustomDropdown();
        customSizeHidden.dispatchEvent(new Event('change', { bubbles: true }));
      });
      customSizeOptions.appendChild(li);
    });
  };

  function openCustomDropdown() {
    customSizeOptions.classList.add('custom-open');
    customSizeCaret.classList.add('custom-open');
  }

  function closeCustomDropdown() {
    customSizeOptions.classList.remove('custom-open');
    customSizeCaret.classList.remove('custom-open');
  }

  customSizeTrigger.addEventListener('click', (e) => {
    e.stopPropagation();

    if (customSizeOptions.classList.contains('custom-open')) {
      closeCustomDropdown();
      return;
    }

    if (customSizeHidden.value) {
      customSizeHidden.value = '';
      customSizeValueEl.textContent = 'Choose your size';
      customSizeOptions.querySelectorAll('li').forEach((item) => item.classList.remove('custom-selected'));
      customSizeHidden.dispatchEvent(new Event('change', { bubbles: true }));
    }

    openCustomDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!customSizeWrapper.contains(e.target)) closeCustomDropdown();
  });

   const openCustomModal = (card) => {
    if (!card) return;

    document.getElementById('customModalProductTitle').textContent = card.dataset.productName || 'Product';
    document.getElementById('customModalProductPrice').textContent = card.dataset.productPrice || '';
    document.getElementById('customModalProductDescription').textContent = card.dataset.productDescription || '';

    const img = card.querySelector('.product-card-image');
    if (img) document.getElementById('customModalProductImage').src = img.src;

    buildCustomColors(card.dataset.productColors);
    buildCustomSizes(card.dataset.productSizes);

    customSizeCaret.classList.remove('custom-open');

    const scrollbarWidth = window.innerWidth - document.documentElement.clientWidth;
    if (scrollbarWidth > 0) {
      document.body.style.paddingRight = scrollbarWidth + 'px';
    }

    customModal.classList.add('custom-active');
    document.documentElement.style.overflow = 'hidden';
    document.body.style.overflow = 'hidden';
  };

  const closeCustomModal = () => {
    customModal.classList.remove('custom-active');
    document.body.style.overflow = '';
    document.body.style.paddingRight = '';
    document.documentElement.style.overflow = '';
  };

  const initCustomModal = () => {
    customCloseBtn.addEventListener('click', closeCustomModal);
    customOverlay.addEventListener('click', closeCustomModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeCustomModal();
    });

    document.addEventListener('click', (e) => {
      const trigger = e.target.closest('[data-product-modal-trigger]');
      if (trigger) {
        e.preventDefault();
        e.stopPropagation();
        openCustomModal(trigger.closest('.product-card'));
      }
    });
  };

  document.addEventListener('DOMContentLoaded', initCustomModal);
</script>

